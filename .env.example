APP_ENV=dev
LOG_LEVEL=INFO
ARCHIVE_ROOT=./data/archive
REDIS_URL=redis://127.0.0.1:6379/0
ENABLE_COLLECTOR=false
ENABLE_INSTRUMENT_MONITOR=false
INSTRUMENT_MONITOR_PING_SECONDS=20
# Binance contractInfo is the real-time source; exchangeInfo polling at this
# interval reconciles state after disconnects.
INSTRUMENT_MONITOR_POLL_SECONDS=60
ENABLE_FACTOR_DERIVATION=false
FACTOR_CONFIRM_DELAY_SECONDS=600
FACTOR_DERIVE_INTERVAL_SECONDS=60
FACTOR_LOOKBACK_SECONDS=21600
FACTOR_MIN_MOVE_PCT=0.05
FACTOR_MAX_ATTEMPTS=10
# Full halt-to-factor lifecycle timeout. Binance equity adjustments can remain
# halted for many hours; this timeout is independent of ordinary retry count.
FACTOR_MAX_WAIT_SECONDS=172800
# Derive factors from official exchange REST klines (authoritative) instead of
# the local store, and flag bars where the local store diverged beyond this pct.
FACTOR_USE_OFFICIAL_KLINES=true
FACTOR_OFFICIAL_DIVERGENCE_PCT=0.02
# Cross-check the derived ratio against the exchange's official announcement.
# A contradicting ratio (beyond tolerance) blocks the factor for manual review.
# require=true also blocks when no matching announcement is found (strict).
FACTOR_VERIFY_ANNOUNCEMENT=true
FACTOR_ANNOUNCEMENT_TOLERANCE_PCT=0.05
FACTOR_REQUIRE_ANNOUNCEMENT=false
CORP_ACTION_NEUTRALIZE_PCT=0.15
CORP_ACTION_PENDING_TTL_SECONDS=1800
CORP_ACTION_RESOLVED_TTL_SECONDS=93600
# Manual instId rename links (semicolon-separated "exchange,successor,predecessor"),
# for renames that change instFamily (e.g. okx,SPCX-USDT-SWAP,SPACEX-USDT-SWAP).
INSTRUMENT_ALIASES=
ENABLE_KLINE_GUARDIAN=false
KLINE_GUARDIAN_AUDIT_INTERVAL_SECONDS=60
KLINE_GUARDIAN_WINDOW_MINUTES=30
KLINE_GUARDIAN_DELAY_SECONDS=120
KLINE_GUARDIAN_SYMBOLS_PER_RUN=50
KLINE_GUARDIAN_REQUEST_DELAY_MS=100
KLINE_GUARDIAN_SYMBOL_MAX_AGE_SECONDS=600
ENABLED_EXCHANGES=binance,okx
USE_MEMORY_STORE=false
ENABLE_MOCK_SYMBOLS=false
HTTP_ADDR=127.0.0.1:8088
DASHBOARD_DIR=./web/dist
RECENT_CACHE_LIMIT=300
FEISHU_WEBHOOK_URL=
HEALTH_REPORT_INTERVAL_SECONDS=30
SYMBOL_REFRESH_INTERVAL_SECONDS=120
ARCHIVE_FLUSH_INTERVAL_SECONDS=5
RECONNECT_BASE_DELAY_SECONDS=1
RECONNECT_MAX_DELAY_SECONDS=60
ENABLE_MYSQL=true
MYSQL_TICK_WRITES_ENABLED=false
MYSQL_BAR_HISTORY_ENABLED=true
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root123
MYSQL_DATABASE=crypto_ticket

BINANCE_KIND=um_futures
BINANCE_REST_URL=https://fapi.binance.com
BINANCE_WS_URL=wss://fstream.binance.com/market
BINANCE_CONTRACT_INFO_WS_URL=wss://fstream.binance.com/market/ws/!contractInfo
BINANCE_CMS_URL=https://www.binance.com
BINANCE_SUBSCRIPTION_CHUNK_SIZE=50
BINANCE_UM_ENABLED=true
BINANCE_COIN_ENABLED=true
BINANCE_COIN_KIND=coin_futures
BINANCE_COIN_REST_URL=https://dapi.binance.com
BINANCE_COIN_WS_URL=wss://dstream.binance.com/ws
BINANCE_COIN_SUBSCRIPTION_CHUNK_SIZE=50

OKX_KIND=swap
OKX_REST_URL=https://www.okx.com
OKX_WS_URL=wss://ws.okx.com:8443/ws/v5/business
# Instruments channel (state/rebase detection) lives on the public endpoint,
# separate from the business endpoint used for candle streams above.
OKX_PUBLIC_WS_URL=wss://ws.okx.com:8443/ws/v5/public
OKX_SUBSCRIPTION_CHUNK_SIZE=120
