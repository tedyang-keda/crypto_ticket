APP_ENV=dev
LOG_LEVEL=INFO
ARCHIVE_ROOT=./data/archive
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_STREAM_MAXLEN=200000
REDIS_CONSUMER_GROUP=crypto_ticket
REDIS_CONSUMER_NAME=local-1
FEISHU_WEBHOOK_URL=
HEALTH_REPORT_INTERVAL_SECONDS=30
SYMBOL_REFRESH_INTERVAL_SECONDS=120
ARCHIVE_FLUSH_INTERVAL_SECONDS=5
BAR_CLOSE_GRACE_SECONDS=2
ENABLE_MYSQL=true
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root123
MYSQL_DATABASE=crypto_ticket

BINANCE_KIND=um_futures
BINANCE_REST_URL=https://fapi.binance.com
BINANCE_WS_URL=wss://fstream.binance.com/ws
BINANCE_TARGET_STREAMS_PER_CONN=1000
BINANCE_SUBSCRIPTION_CHUNK_SIZE=200

OKX_KIND=swap
OKX_REST_URL=https://www.okx.com
OKX_WS_URL=wss://ws.okx.com:8443/ws/v5/public
OKX_TARGET_STREAMS_PER_CONN=1000
OKX_SUBSCRIPTION_CHUNK_SIZE=120
