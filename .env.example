APP_ENV=dev
LOG_LEVEL=INFO
ARCHIVE_ROOT=./data/archive
REDIS_URL=redis://127.0.0.1:6379/0
ENABLE_COLLECTOR=false
ENABLE_KLINE_GUARDIAN=false
KLINE_GUARDIAN_AUDIT_INTERVAL_SECONDS=60
KLINE_GUARDIAN_WINDOW_MINUTES=30
KLINE_GUARDIAN_DELAY_SECONDS=120
KLINE_GUARDIAN_SYMBOLS_PER_RUN=50
KLINE_GUARDIAN_REQUEST_DELAY_MS=100
ENABLED_EXCHANGES=binance,okx
USE_MEMORY_STORE=false
ENABLE_MOCK_SYMBOLS=false
HTTP_ADDR=127.0.0.1:8088
DASHBOARD_DIR=./web/dist
RECENT_CACHE_LIMIT=300
FEISHU_WEBHOOK_URL=
HEALTH_REPORT_INTERVAL_SECONDS=30
SYMBOL_REFRESH_INTERVAL_SECONDS=120
ARCHIVE_FLUSH_INTERVAL_SECONDS=5
RECONNECT_BASE_DELAY_SECONDS=1
RECONNECT_MAX_DELAY_SECONDS=60
ENABLE_MYSQL=true
MYSQL_TICK_WRITES_ENABLED=false
MYSQL_BAR_HISTORY_ENABLED=true
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root123
MYSQL_DATABASE=crypto_ticket

BINANCE_KIND=um_futures
BINANCE_REST_URL=https://fapi.binance.com
BINANCE_WS_URL=wss://fstream.binance.com/market
BINANCE_SUBSCRIPTION_CHUNK_SIZE=50
BINANCE_UM_ENABLED=true
BINANCE_COIN_ENABLED=true
BINANCE_COIN_KIND=coin_futures
BINANCE_COIN_REST_URL=https://dapi.binance.com
BINANCE_COIN_WS_URL=wss://dstream.binance.com/ws
BINANCE_COIN_SUBSCRIPTION_CHUNK_SIZE=50

OKX_KIND=swap
OKX_REST_URL=https://www.okx.com
OKX_WS_URL=wss://ws.okx.com:8443/ws/v5/business
OKX_SUBSCRIPTION_CHUNK_SIZE=120
